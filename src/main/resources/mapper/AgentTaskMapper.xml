<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kama.jchatmind.mapper.AgentTaskMapper">

    <resultMap id="BaseResultMap" type="com.kama.jchatmind.model.entity.AgentTask">
        <id property="id" column="id" jdbcType="VARCHAR"/>
        <result property="sessionId" column="session_id" jdbcType="VARCHAR"/>
        <result property="agentId" column="agent_id" jdbcType="VARCHAR"/>
        <result property="userMessageId" column="user_message_id" jdbcType="VARCHAR"/>
        <result property="status" column="status" jdbcType="VARCHAR"/>
        <result property="goal" column="goal" jdbcType="VARCHAR"/>
        <result property="startedAt" column="started_at" jdbcType="TIMESTAMP"/>
        <result property="finishedAt" column="finished_at" jdbcType="TIMESTAMP"/>
        <result property="errorMessage" column="error_message" jdbcType="VARCHAR"/>
    </resultMap>

    <insert id="insert" parameterType="com.kama.jchatmind.model.entity.AgentTask"
            keyColumn="id" keyProperty="id" useGeneratedKeys="true">
        INSERT INTO agent_task
        (session_id, agent_id, user_message_id, status, goal, started_at, finished_at, error_message)
        VALUES
        (CAST(#{sessionId} AS uuid),
         CAST(#{agentId} AS uuid),
         CAST(#{userMessageId} AS uuid),
         #{status},
         #{goal},
         #{startedAt},
         #{finishedAt},
         #{errorMessage})
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT id,
               session_id,
               agent_id,
               user_message_id,
               status,
               goal,
               started_at,
               finished_at,
               error_message
        FROM agent_task
        WHERE id = CAST(#{id} AS uuid)
    </select>

    <update id="updateById" parameterType="com.kama.jchatmind.model.entity.AgentTask">
        UPDATE agent_task
        <set>
            <if test="status != null">status = #{status},</if>
            <if test="goal != null">goal = #{goal},</if>
            <if test="finishedAt != null">finished_at = #{finishedAt},</if>
            <if test="errorMessage != null">error_message = #{errorMessage},</if>
        </set>
        WHERE id = CAST(#{id} AS uuid)
    </update>
</mapper>
