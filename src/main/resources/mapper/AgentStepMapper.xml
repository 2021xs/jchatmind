<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kama.jchatmind.mapper.AgentStepMapper">

    <resultMap id="BaseResultMap" type="com.kama.jchatmind.model.entity.AgentStep">
        <id property="id" column="id" jdbcType="VARCHAR"/>
        <result property="taskId" column="task_id" jdbcType="VARCHAR"/>
        <result property="stepNo" column="step_no" jdbcType="INTEGER"/>
        <result property="stepType" column="step_type" jdbcType="VARCHAR"/>
        <result property="status" column="status" jdbcType="VARCHAR"/>
        <result property="inputSummary" column="input_summary" jdbcType="VARCHAR"/>
        <result property="outputSummary" column="output_summary" jdbcType="VARCHAR"/>
        <result property="startedAt" column="started_at" jdbcType="TIMESTAMP"/>
        <result property="finishedAt" column="finished_at" jdbcType="TIMESTAMP"/>
        <result property="errorMessage" column="error_message" jdbcType="VARCHAR"/>
    </resultMap>

    <insert id="insert" parameterType="com.kama.jchatmind.model.entity.AgentStep"
            keyColumn="id" keyProperty="id" useGeneratedKeys="true">
        INSERT INTO agent_step
        (task_id, step_no, step_type, status, input_summary, output_summary, started_at, finished_at, error_message)
        VALUES
        (CAST(#{taskId} AS uuid),
         #{stepNo},
         #{stepType},
         #{status},
         #{inputSummary},
         #{outputSummary},
         #{startedAt},
         #{finishedAt},
         #{errorMessage})
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT id,
               task_id,
               step_no,
               step_type,
               status,
               input_summary,
               output_summary,
               started_at,
               finished_at,
               error_message
        FROM agent_step
        WHERE id = CAST(#{id} AS uuid)
    </select>

    <update id="updateById" parameterType="com.kama.jchatmind.model.entity.AgentStep">
        UPDATE agent_step
        <set>
            <if test="status != null">status = #{status},</if>
            <if test="outputSummary != null">output_summary = #{outputSummary},</if>
            <if test="finishedAt != null">finished_at = #{finishedAt},</if>
            <if test="errorMessage != null">error_message = #{errorMessage},</if>
        </set>
        WHERE id = CAST(#{id} AS uuid)
    </update>
</mapper>
